<Window x:Class="MeetingTranslator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Subtítulos" Height="250" Width="800"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">

    <Border Background="#CC000000" CornerRadius="10" Padding="20" MouseLeftButtonDown="ArrastrarVentana">

        <ScrollViewer x:Name="ScrollSubtitulos" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

            <StackPanel x:Name="PanelHistorial" VerticalAlignment="Bottom">
                <TextBlock Foreground="LightGray" FontSize="18" Text="Iniciando interfaz..."/>
                <TextBlock Foreground="White" FontSize="24" FontWeight="Bold" Text="Buscando conexión..." Margin="0,0,0,15"/>
            </StackPanel>

        </ScrollViewer>
    </Border>
</Window>